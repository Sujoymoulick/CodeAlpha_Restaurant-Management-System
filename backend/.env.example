# ==============================================================================
# RESTAURANT MANAGEMENT SYSTEM - BACKEND ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================================

# 1. Server Configuration
PORT=5050

# 2. Database Connection
# Replace with your local URI or MongoDB Atlas Cluster URL
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/restaurant_management?retryWrites=true&w=majority

# 3. Security Configuration
# Set a unique, strong JWT secret key
JWT_SECRET=your_jwt_secret_key_here

# 4. CORS configuration
# Point to your frontend application's URL
CLIENT_ORIGIN=http://localhost:3000
